{
  "name": "hypertrophy-bible-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "The Hypertrophy Bible app — a coach that has already made every decision. Runs on Node locally and Cloudflare Workers in production.",
  "scripts": {
    "build-data": "node scripts/gen-kb-data.mjs && node scripts/gen-learn-data.mjs",
    "dev": "npm run build-data && node server.node.mjs",
    "start": "node server.node.mjs",
    "test": "node scripts/test-coach.mjs && node scripts/test-auth.mjs && node scripts/test-adherence.mjs",
    "db:init:local": "wrangler d1 execute hypertrophy-bible --local --file=./schema.sql",
    "db:init:remote": "wrangler d1 execute hypertrophy-bible --remote --file=./schema.sql",
    "cf:dev": "npm run build-data && wrangler dev",
    "deploy": "npm run build-data && wrangler deploy"
  },
  "dependencies": {
    "hono": "^4.6.14",
    "@hono/node-server": "^1.13.7"
  },
  "devDependencies": {
    "wrangler": "^3.99.0"
  }
}
