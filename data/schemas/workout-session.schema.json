{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hypertrophy-bible.dev/schemas/workout-session.json",
  "title": "WorkoutSession",
  "description": "The crown-jewel data stream: one training session as a list of sets. Objective primitives (exercise, weight, reps) plus optional effort/timestamps. Higher-order metrics (per-muscle volume, est. 1RM, rest times, proximity to failure) are DERIVED, never asked (see tools/derive-metrics.mjs).",
  "type": "object",
  "additionalProperties": false,
  "required": ["session_id", "user_id", "date", "sets"],
  "properties": {
    "session_id": { "type": "string" },
    "user_id": { "type": "string" },
    "date": { "type": "string", "format": "date-time" },
    "program_ref": { "type": "string", "description": "id of the program-template driving this session" },
    "session_name": { "type": "string" },
    "bodyweight_kg": { "type": "number", "minimum": 25, "maximum": 400 },
    "sets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["exercise", "weight_kg", "reps"],
        "properties": {
          "exercise": { "type": "string", "description": "exercise id (resolves against data/exercises)" },
          "set_type": { "enum": ["work", "warmup", "backoff", "drop", "myo-rep", "amrap", "rest-pause"] },
          "weight_kg": { "type": "number", "minimum": 0, "maximum": 1000 },
          "reps": { "type": "integer", "minimum": 0, "maximum": 100 },
          "rpe": { "type": "number", "minimum": 5, "maximum": 10, "multipleOf": 0.5 },
          "rir": { "type": "integer", "minimum": 0, "maximum": 10 },
          "is_bodyweight": { "type": "boolean" },
          "completed_at": { "type": "string", "format": "date-time", "description": "set completion timestamp, enables rest-time derivation" },
          "notes": { "type": "string" }
        }
      }
    },
    "session_rpe": { "type": "number", "minimum": 1, "maximum": 10 },
    "duration_min": { "type": "integer", "minimum": 1, "maximum": 360 }
  }
}
