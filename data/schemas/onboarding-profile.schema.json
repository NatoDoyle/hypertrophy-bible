{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hypertrophy-bible.dev/schemas/onboarding-profile.json",
  "title": "OnboardingProfile",
  "description": "One-time user profile. Only the minimum needed to generate a good first program is required; the rest is collected progressively over the first weeks (see docs/data-and-learning-spec.md).",
  "type": "object",
  "additionalProperties": false,
  "required": ["user_id", "units", "sex", "training_status", "primary_goal", "days_per_week", "available_equipment"],
  "properties": {
    "user_id": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "units": { "enum": ["metric", "imperial"] },
    "sex": { "enum": ["male", "female", "intersex", "prefer-not-to-say"] },
    "birth_year": { "type": "integer", "minimum": 1900, "maximum": 2025 },
    "height_cm": { "type": "number", "minimum": 100, "maximum": 260 },
    "bodyweight_kg": { "type": "number", "minimum": 25, "maximum": 400 },
    "training_status": { "enum": ["beginner", "intermediate", "advanced"] },
    "experience_years": { "type": "number", "minimum": 0, "maximum": 80 },
    "primary_goal": { "enum": ["hypertrophy", "strength", "recomposition", "fat-loss", "general-fitness"] },
    "priority_muscles": {
      "type": "array",
      "items": { "type": "string", "description": "muscle id to bias volume toward" }
    },
    "days_per_week": { "type": "integer", "minimum": 1, "maximum": 7 },
    "session_length_min": { "type": "integer", "minimum": 10, "maximum": 240 },
    "available_equipment": {
      "type": "array",
      "minItems": 1,
      "items": { "enum": ["barbell", "dumbbell", "machine", "cable", "bodyweight"], "description": "Only equipment the exercise library actually covers — band/kettlebell/smith-machine are omitted until primary exercises exist for them, so a user can't select an equipment set that resolves to an empty pool." }
    },
    "injuries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["region"],
        "properties": {
          "region": { "enum": ["lower-back", "knee", "shoulder", "elbow", "wrist", "hip", "neck", "ankle"], "description": "Must match a key in data/injury-contraindications.json so the exclusion rule actually resolves." },
          "severity": { "enum": ["mild", "moderate", "severe"] },
          "note": { "type": "string" }
        }
      }
    },
    "wearable": { "enum": ["none", "apple-health", "garmin", "oura", "whoop", "fitbit", "other"] },
    "menstrual_tracking": { "type": "boolean" },
    "dietary_pattern": { "enum": ["omnivore", "vegetarian", "vegan", "pescatarian", "other"] },
    "rir_calibrated": {
      "type": "boolean",
      "description": "Whether the user has demonstrated reliable RIR estimation (gates trust in self-reported effort)."
    }
  }
}
