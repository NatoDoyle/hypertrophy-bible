{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hypertrophy-bible.dev/schemas/program-template.json",
  "title": "ProgramTemplate",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "split", "days_per_week", "sessions"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "name": { "type": "string" },
    "split": {
      "enum": ["full-body", "upper-lower", "push-pull-legs", "body-part", "push-pull", "other"]
    },
    "days_per_week": { "type": "integer", "minimum": 1, "maximum": 7 },
    "experience_level": {
      "type": "array",
      "items": { "enum": ["beginner", "intermediate", "advanced"] }
    },
    "target_population": { "type": "string" },
    "progression_ref": { "type": "string", "description": "id of a progression-rule" },
    "sessions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "exercises"],
        "properties": {
          "name": { "type": "string" },
          "exercises": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["exercise", "sets", "rep_range"],
              "properties": {
                "exercise": { "type": "string", "description": "Exercise id or name" },
                "sets": { "type": "integer", "minimum": 1, "maximum": 10 },
                "rep_range": { "type": "string", "description": "e.g. '6-10'" },
                "rir": { "type": "string", "description": "Target reps in reserve, e.g. '1-3'" },
                "notes": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "citations": { "type": "array", "items": { "type": "string" } }
  }
}
